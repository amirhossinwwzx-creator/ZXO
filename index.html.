<script>
  // Marquee bulbs around the wheel
  (function(){
    var marquee = document.getElementById('marquee');
    var count = 16;
    for(var i=0;i<count;i++){
      var deg = i * (360/count);
      var b = document.createElement('div');
      b.className = 'bulb';
      b.style.transform = 'translate(-50%,-50%) rotate('+deg+'deg) translate(0,-190px)';
      b.style.animationDelay = (i * 0.08) + 's';
      marquee.appendChild(b);
    }
  })();

  // Wheel of fortune (demo — anyone can spin anytime, no persistence)
  var segments = [5,10,15,20,30,40,60,80]; // clockwise from top, 45deg each
  var spinning = false;
  var currentRotation = 0;

  function spinWheel(){
    if(spinning) return;
    spinning = true;
    var btn = document.getElementById('spinBtn');
    var result = document.getElementById('wheelResult');
    btn.disabled = true;
    result.textContent = 'در حال چرخش...';

    var extraTurns = 5 + Math.floor(Math.random()*3); // 5-7 full turns
    var randomOffset = Math.random() * 360;
    var newRotation = currentRotation + extraTurns*360 + randomOffset;
    currentRotation = newRotation;

    var wheel = document.getElementById('wheel');
    wheel.style.transform = 'rotate(' + newRotation + 'deg)';

    setTimeout(function(){
      var normalized = (360 - (newRotation % 360)) % 360;
      var index = Math.floor(normalized / 45) % 8;
      var prize = segments[index];
      result.textContent = 'شانس آوردی! 💎 ' + prize + ' جم بردی';
      btn.disabled = false;
      spinning = false;
    }, 4200);
  }

  function sendJoinRequest(){
    var name = document.getElementById('fName').value.trim();
    var tag = document.getElementById('fTag').value.trim();
    var th = document.getElementById('fTh').value.trim();
    var trophy = document.getElementById('fTrophy').value.trim();
    var contact = document.getElementById('fContact').value.trim();
    var status = document.getElementById('formStatus');

    if(!name || !tag || !th){
      status.textContent = 'لطفاً حداقل نام، تگ و لول تاون‌هال رو پر کن.';
      status.style.color = '#E22E75';
      return;
    }

    var msg = 'درخواست عضویت در ZXO' + '\n' +
              'نام: ' + name + '\n' +
              'تگ: ' + tag + '\n' +
              'تاون‌هال: ' + th + '\n' +
              'ترافی: ' + (trophy || '-') + '\n' +
              'آیدی تماس: ' + (contact || '-');

    var url = 'https://t.me/share/url?url=' + encodeURIComponent('https://t.me/ZXOCLN') + '&text=' + encodeURIComponent(msg);
    status.textContent = 'در حال باز کردن تلگرام...';
    status.style.color = '#17B884';
    window.open(url, '_blank');
  }
</script>

